
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isUser(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function getUserData() {
      let userPath = /databases/$(database)/documents/users/$(request.auth.uid);
      return exists(userPath) ? get(userPath).data : null;
    }

    // ROBUST ORG CHECK: Prioritize token claims (fast), fallback to simple UID check
    function isOrgMember(resourceOrgId) {
      let userPath = /databases/$(database)/documents/users/$(request.auth.uid);
      let isDirectMember = isSignedIn() && (
        (request.auth.token.organizationId != null && request.auth.token.organizationId == resourceOrgId) ||
        (exists(userPath) && get(userPath).data.get('organizationId', '') == resourceOrgId)
      );
      return isDirectMember || isOrgFranchiseAdmin(resourceOrgId);
    }
    
    function isFranchiseAdmin(docFranchiseId) {
      let userData = getUserData();
      return isSignedIn() && userData != null && userData.get('role', '') == 'franchise_admin' && docFranchiseId != null && userData.get('franchiseId', 'X') == docFranchiseId;
    }

    function isOrgFranchiseAdmin(orgId) {
      let orgPath = /databases/$(database)/documents/organizations/$(orgId);
      let orgData = exists(orgPath) ? get(orgPath).data : null;
      return orgData != null && isFranchiseAdmin(orgData.get('franchiseId', 'X'));
    }
    
    // Checks if user is an admin (UID or Email keyed)
    function isOrgAdmin() {
      let userPathByUid = /databases/$(database)/documents/users/$(request.auth.uid);
      let userPathByEmail = /databases/$(database)/documents/users/$(request.auth.token.email);
      let userData = exists(userPathByUid) ? get(userPathByUid).data : 
                     (exists(userPathByEmail) ? get(userPathByEmail).data : null);
                     
      return isSignedIn() && (
        (request.auth.token.role != null && request.auth.token.role in ['admin', 'master_admin', 'both', 'supervisor']) ||
        (userData != null && (userData.role in ['admin', 'master_admin', 'both', 'supervisor']))
      );
    }

    // Checks if user is a Master Admin (superuser)
    function isMaster() {
      return isSignedIn() && (
        (request.auth.token.role != null && request.auth.token.role == 'master_admin') || 
        (getUserData() != null && getUserData().role == 'master_admin')
      );
    }
    
    // Checks if user is a Platform Sales Rep
    function isPlatformSales() {
      return isSignedIn() && (
        (request.auth.token.role != null && request.auth.token.role == 'platform_sales') ||
        (getUserData() != null && getUserData().role == 'platform_sales')
      );
    }

    // Checks if user is a customer (UID or Email keyed)
    function isCustomer() {
      let userPathByUid = /databases/$(database)/documents/users/$(request.auth.uid);
      let userPathByEmail = /databases/$(database)/documents/users/$(request.auth.token.email);
      let userData = exists(userPathByUid) ? get(userPathByUid).data : 
                     (exists(userPathByEmail) ? get(userPathByEmail).data : null);
                     
      return isSignedIn() && (
        (request.auth.token.role != null && request.auth.token.role == 'customer') ||
        (userData != null && userData.role == 'customer')
      );
    }

    // Checks if the user is the customer assigned to this document
    function isCustomerOwner(resourceData) {
      // Direct UID match (for Doc ID) or field match
      return isSignedIn() && resourceData != null && (
        (resourceData.userId != null && resourceData.userId == request.auth.uid) ||
        (resourceData.customerId != null && resourceData.customerId == request.auth.uid) ||
        (resourceData.email != null && request.auth.token.email != null && resourceData.email == request.auth.token.email) ||
        (resourceData.customerEmail != null && request.auth.token.email != null && resourceData.customerEmail == request.auth.token.email) ||
        (resourceData.id != null && resourceData.id == request.auth.uid)
      );
    }

    // Check if the user's organization is the assigned partner for the job
    function isAssignedPartner(resourceData) {
      return isSignedIn() && 
             resourceData.assignedPartnerId != null &&
             isOrgMember(resourceData.assignedPartnerId);
    }
    
    // --- Core Collections ---

    match /users/{userId} {
      allow get: if isMaster() 
                 || (resource != null && isFranchiseAdmin(resource.data.get('franchiseId', null)))
                 || isUser(userId) 
                 || (isSignedIn() && request.auth.token.email != null && request.auth.token.email == userId) 
                 || (isSignedIn() && resource != null && resource.data.email != null && request.auth.token.email != null && request.auth.token.email == resource.data.email)
                 || (resource != null && isOrgMember(resource.data.organizationId));
                 
      allow list: if isMaster() || isPlatformSales() || (resource != null && isFranchiseAdmin(resource.data.get('franchiseId', null))) || (resource != null && isOrgMember(resource.data.organizationId)) || (isSignedIn() && resource != null && resource.data.email != null && request.auth.token.email != null && resource.data.email == request.auth.token.email); 
      
      allow write: if isMaster() || isPlatformSales() || (resource != null && isFranchiseAdmin(resource.data.get('franchiseId', null))) || isUser(userId) || (isOrgAdmin() && resource != null && isOrgMember(resource.data.organizationId));
      allow create: if isSignedIn();
    }

    // Organizations: Public read for login/branding, Admin write only.
    match /organizations/{orgId} {
      allow read: if true; 
      allow create: if isSignedIn();
      allow update, delete: if isMaster() || isPlatformSales() || (isOrgMember(orgId) && isOrgAdmin());
      
      match /secrets/{secretId} {
         allow read, write: if isMaster() || isPlatformSales() || (isOrgMember(orgId) && isOrgAdmin());
      }

      match /marketingTemplates/{templateId} {
         allow read, write: if isMaster() || isPlatformSales() || (isOrgMember(orgId) && isOrgAdmin());
      }

      match /socialMediaTemplates/{templateId} {
         allow read, write: if isMaster() || isPlatformSales() || isOrgMember(orgId);
      }

      match /socialMediaPosts/{postId} {
         allow read, write: if isMaster() || isPlatformSales() || isOrgMember(orgId);
      }
      
      match /jobs/{jobId}/ai_messages/{msgId} {
         allow read, write: if isMaster() || isPlatformSales() || isOrgMember(orgId);
      }

      match /blogPosts/{postId} {
         allow read: if true;
         allow write: if isMaster() || isPlatformSales() || isOrgMember(orgId);
      }

      match /ai_context/{contextId} {
         allow read, write: if isMaster() || isPlatformSales() || (isOrgMember(orgId) && isOrgAdmin());
      }

      match /settings/{settingId} {
         allow read: if isMaster() || isPlatformSales() || isOrgMember(orgId);
         allow write: if isMaster() || isPlatformSales() || (isOrgMember(orgId) && isOrgAdmin());
      }

      match /warrantyClaims/{claimId} {
         allow read, write: if isMaster() || isPlatformSales() || isOrgMember(orgId);
      }

      match /aiLongTasks/{taskId} {
         allow read: if isMaster() || isPlatformSales() || isOrgMember(orgId);
         allow write: if false; // Written only by Cloud Functions
      }
    }

    match /franchises/{franchiseDocId} {
       allow read: if true; // Public array access for DNS Domain mapping
       allow write: if isMaster() || isFranchiseAdmin(franchiseDocId);
    }

    // Customers: Accessible by organization members or the customer themselves.
    match /customers/{customerId} {
      allow read: if isMaster() || isPlatformSales() || (resource != null && isFranchiseAdmin(resource.data.get('franchiseId', null))) || (resource != null && isOrgMember(resource.data.organizationId)) || (resource != null && isCustomerOwner(resource.data)) || request.auth.uid == customerId || (isSignedIn() && resource != null && resource.data.email != null && request.auth.token.email != null && resource.data.email == request.auth.token.email) || (isSignedIn() && resource != null && resource.data.userId == request.auth.uid);
      allow write: if isMaster() || (resource != null && isOrgMember(resource.data.organizationId)) || (resource != null && isCustomerOwner(resource.data)) || request.auth.uid == customerId;
      allow create: if isMaster() || isOrgMember(request.resource.data.organizationId) || (request.resource.data.email != null && request.auth.token.email != null && request.resource.data.email == request.auth.token.email) || request.auth.uid == customerId;
    }

    match /appointments/{appointmentId} {
      allow read: if isMaster() || isPlatformSales() || (resource != null && isFranchiseAdmin(resource.data.get('franchiseId', null))) || isOrgMember(resource.data.organizationId) || isCustomerOwner(resource.data);
      allow write: if isMaster() || (resource != null && isFranchiseAdmin(resource.data.get('franchiseId', null))) || isOrgMember(resource.data.organizationId);
      allow create: if isMaster() || isOrgMember(request.resource.data.organizationId) || isCustomerOwner(request.resource.data);
    }

    match /jobs/{jobId} {
      allow get: if true;
      allow list: if isMaster() || isPlatformSales() || (resource != null && isFranchiseAdmin(resource.data.get('franchiseId', null))) || isAssignedPartner(resource.data) || isOrgMember(resource.data.organizationId) || isCustomerOwner(resource.data);
      allow write: if isMaster() || isPlatformSales() || (resource != null && isFranchiseAdmin(resource.data.get('franchiseId', null))) || isOrgMember(resource.data.organizationId) || isAssignedPartner(resource.data) || isCustomerOwner(resource.data);
      allow create: if isMaster() || isPlatformSales() || isOrgMember(request.resource.data.organizationId);
      
      match /ai_messages/{msgId} {
        allow read, write: if isMaster() || 
                             isPlatformSales() || 
                             isOrgMember(resource.data.organizationId) || 
                             isCustomerOwner(resource.data) ||
                             isAssignedPartner(resource.data);
      }
      
      match /diagnostics/{reportId} {
         allow read: if isMaster() || isPlatformSales() || isOrgMember(get(/databases/$(database)/documents/jobs/$(jobId)).data.organizationId);
         allow write: if false; // Only written by trusted Cloud Functions (measureQuickWebhook)
      }
    }

    match /invoices/{invoiceId} {
      allow get: if true;
      allow list: if isMaster() || isPlatformSales() || isOrgMember(resource.data.organizationId) || isCustomerOwner(resource.data);
      allow read, write: if isMaster() || isPlatformSales() || isOrgMember(resource.data.organizationId);
    }
    
    // Allow users to generate outbound system emails via batch write extensions
    match /mail/{mailId} {
      allow create: if isSignedIn();
    }

    match /inventory/{itemId} {
      allow read: if isMaster() || isPlatformSales() || isOrgMember(resource.data.organizationId);
      allow write: if isMaster() || isOrgMember(resource.data.organizationId);
      allow create: if isMaster() || isOrgMember(request.resource.data.organizationId);
    }

    match /expenses/{expenseId} {
      allow read: if isMaster() || isPlatformSales() || isOrgMember(resource.data.organizationId);
      allow write: if isMaster() || isOrgMember(resource.data.organizationId);
      allow create: if isMaster() || isOrgMember(request.resource.data.organizationId);
    }

    match /payables/{payableId} {
      allow read: if isMaster() || isPlatformSales() || isOrgMember(resource.data.organizationId);
      allow write: if isMaster() || isOrgMember(resource.data.organizationId);
      allow create: if isMaster() || isOrgMember(request.resource.data.organizationId);
    }

    match /proposals/{proposalId} {
      allow read: if true; 
      allow write: if isMaster() || isPlatformSales() || (resource != null && isFranchiseAdmin(resource.data.get('franchiseId', null))) || isOrgMember(resource.data.organizationId);
      allow create: if isMaster() || isPlatformSales() || isOrgMember(request.resource.data.organizationId);
    }
    
    match /proposalPresets/{presetId} {
      allow read: if isMaster() || isPlatformSales() || isOrgMember(resource.data.organizationId);
      allow write: if isMaster() || isOrgMember(resource.data.organizationId);
      allow create: if isMaster() || isOrgMember(request.resource.data.organizationId);
    }

    match /serviceAgreements/{agreementId} {
      allow read: if isMaster() || isPlatformSales() || (resource != null && isFranchiseAdmin(resource.data.get('franchiseId', null))) || isOrgMember(resource.data.organizationId) || isCustomerOwner(resource.data);
      allow write: if isMaster() || (resource != null && isFranchiseAdmin(resource.data.get('franchiseId', null))) || isOrgMember(resource.data.organizationId);
      allow create: if isMaster() || isOrgMember(request.resource.data.organizationId) || isCustomerOwner(request.resource.data);
    }
    
    match /membershipPlans/{planId} {
      allow read: if true; 
      allow write: if isMaster() || isOrgMember(resource.data.organizationId);
      allow create: if isMaster() || isOrgMember(request.resource.data.organizationId);
    }

    match /partOrders/{orderId} {
      allow read: if isMaster() || isPlatformSales() || isOrgMember(resource.data.organizationId);
      allow write: if isMaster() || isOrgMember(resource.data.organizationId);
      allow create: if isMaster() || isOrgMember(request.resource.data.organizationId);
    }

    match /shopOrders/{orderId} {
      allow read: if isMaster() || isPlatformSales() || isOrgMember(resource.data.organizationId);
      allow write: if isMaster() || isOrgMember(resource.data.organizationId);
      allow create: if isMaster() || isOrgMember(request.resource.data.organizationId);
    }

    match /projects/{projectId} {
      allow read: if isMaster() || isPlatformSales() || isOrgMember(resource.data.organizationId) || isCustomerOwner(resource.data);
      allow write: if isMaster() || isOrgMember(resource.data.organizationId);
      allow create: if isMaster() || isOrgMember(request.resource.data.organizationId);
    }
    
    match /project_notes/{noteId} {
       allow read: if isMaster() || isPlatformSales() || isOrgMember(resource.data.organizationId);
       allow write: if isMaster() || isOrgMember(resource.data.organizationId);
       allow create: if isMaster() || isOrgMember(request.resource.data.organizationId);
    }

    match /project_tasks/{taskId} {
      allow read: if isMaster() || isPlatformSales() || isOrgMember(resource.data.organizationId);
      allow write: if isMaster() || isOrgMember(resource.data.organizationId);
      allow create: if isMaster() || isOrgMember(request.resource.data.organizationId);
    }

    match /permits/{permitId} {
      allow read: if isMaster() || isPlatformSales() || isOrgMember(resource.data.organizationId);
      allow write: if isMaster() || isOrgMember(resource.data.organizationId);
      allow create: if isMaster() || isOrgMember(request.resource.data.organizationId);
    }

    match /equipment_rentals/{rentalId} {
      allow read: if isMaster() || isPlatformSales() || isOrgMember(resource.data.organizationId);
      allow write: if isMaster() || isOrgMember(resource.data.organizationId);
      allow create: if isMaster() || isOrgMember(request.resource.data.organizationId);
    }

    match /subcontractors/{subId} {
      allow read: if isMaster() || isPlatformSales() || isOrgMember(resource.data.organizationId);
      allow write: if isMaster() || isOrgMember(resource.data.organizationId);
      allow create: if isMaster() || isOrgMember(request.resource.data.organizationId);
    }

    match /teams/{teamId} {
      allow read, list: if isMaster() || isPlatformSales() || isOrgMember(resource.data.organizationId);
      allow write: if isMaster() || isOrgMember(resource.data.organizationId);
      allow create: if isMaster() || isOrgMember(request.resource.data.organizationId);
    }

    match /bids/{bidId} {
      allow read: if isMaster() || isPlatformSales() || isOrgMember(resource.data.organizationId);
      allow write: if isMaster() || isOrgMember(resource.data.organizationId);
      allow create: if isMaster() || isOrgMember(request.resource.data.organizationId);
    }

    match /leads/{leadId} {
      allow read: if isMaster() || isPlatformSales() || isOrgMember(resource.data.organizationId);
      allow write: if isMaster() || isOrgMember(resource.data.organizationId);
      allow create: if isSignedIn();
    }
    
    match /platformLeads/{leadId} {
       allow read, write: if isMaster() || isPlatformSales() || (resource != null && isFranchiseAdmin(resource.data.get('franchiseId', null))) || isOrgMember(resource.data.organizationId);
       allow create: if isMaster() || isPlatformSales() || isFranchiseAdmin(request.resource.data.get('franchiseId', null)) || isOrgMember(request.resource.data.organizationId);
    }
    
    match /platform_leads/{leadId} {
       allow read, write: if isMaster() || isPlatformSales() || (resource != null && isFranchiseAdmin(resource.data.get('franchiseId', null))) || isOrgMember(resource.data.organizationId);
       allow create: if isMaster() || isPlatformSales() || isFranchiseAdmin(request.resource.data.get('franchiseId', null)) || isOrgMember(request.resource.data.organizationId);
    }

    match /marketingCampaigns/{campaignId} {
      allow read: if isMaster() || isPlatformSales() || isOrgMember(resource.data.organizationId);
      allow write: if isMaster() || isOrgMember(resource.data.organizationId);
      allow create: if isMaster() || isOrgMember(request.resource.data.organizationId);
    }
    
    match /sales_campaigns/{campaignId} {
      allow read, write: if isMaster() || isPlatformSales();
    }
    
    match /sales_templates/{templateId} {
      allow read, write: if isMaster() || isPlatformSales();
    }
    
    match /salesResources/{resourceId} {
      allow read, write: if isMaster() || isPlatformSales();
    }

    match /commissions/{commId} {
      allow read: if isMaster() || isPlatformSales() || isOrgMember(resource.data.organizationId);
      allow write: if isMaster() || isOrgMember(resource.data.organizationId);
      allow create: if isMaster() || isOrgMember(request.resource.data.organizationId);
    }
    
    match /platformCommissions/{commId} {
        allow read, write: if isMaster() || isPlatformSales() || (resource != null && isFranchiseAdmin(resource.data.get('franchiseId', null))) || isOrgMember(resource.data.organizationId) || isUser(resource.data.repId);
        allow create: if isMaster() || isPlatformSales() || isFranchiseAdmin(request.resource.data.get('franchiseId', null)) || isOrgMember(request.resource.data.organizationId);
    }
    
    match /platform_commissions/{commId} {
        allow read, write: if isMaster() || isPlatformSales() || (resource != null && isFranchiseAdmin(resource.data.get('franchiseId', null))) || isOrgMember(resource.data.organizationId) || isUser(resource.data.repId);
        allow create: if isMaster() || isPlatformSales() || isFranchiseAdmin(request.resource.data.get('franchiseId', null)) || isOrgMember(request.resource.data.organizationId);
    }
    
    match /salesActivities/{activityId} {
       allow read, write: if isMaster() || isPlatformSales() || isUser(resource.data.repId);
    }

    match /workSchedules/{scheduleId} {
      allow read: if isMaster() || isPlatformSales() || isOrgMember(resource.data.organizationId);
      allow write: if isMaster() || isOrgMember(resource.data.organizationId);
      allow create: if isMaster() || isOrgMember(request.resource.data.organizationId);
    }
    
    match /shiftLogs/{shiftId} {
      allow read: if isMaster() || isPlatformSales() || isOrgMember(resource.data.organizationId);
      allow write: if isMaster() || isOrgMember(resource.data.organizationId);
      allow create: if isMaster() || isOrgMember(request.resource.data.organizationId);
    }
    
    match /shifts/{shiftId} {
      allow read: if isMaster() || isPlatformSales() || isOrgMember(resource.data.organizationId);
      allow write: if isMaster() || isOrgMember(resource.data.organizationId);
      allow create: if isMaster() || isOrgMember(request.resource.data.organizationId);
    }

    match /vehicleLogs/{logId} {
      allow read: if isMaster() || isPlatformSales() || isOrgMember(resource.data.organizationId);
      allow write: if isMaster() || isOrgMember(resource.data.organizationId);
      allow create: if isMaster() || isOrgMember(request.resource.data.organizationId);
    }

    match /vehicle_logs/{logId} {
      allow read: if isMaster() || isPlatformSales() || isOrgMember(resource.data.organizationId);
      allow write: if isMaster() || isOrgMember(resource.data.organizationId);
      allow create: if isMaster() || isOrgMember(request.resource.data.organizationId);
    }
    
    match /vehicles/{vehicleId} {
      allow read: if isMaster() || isPlatformSales() || isOrgMember(resource.data.organizationId);
      allow write: if isMaster() || isOrgMember(resource.data.organizationId);
      allow create: if isMaster() || isOrgMember(request.resource.data.organizationId);
    }
    
    match /toolMaintenanceLogs/{logId} {
      allow read: if isMaster() || isPlatformSales() || isOrgMember(resource.data.organizationId);
      allow write: if isMaster() || isOrgMember(resource.data.organizationId);
      allow create: if isMaster() || isOrgMember(request.resource.data.organizationId);
    }

    match /refrigerantCylinders/{cylId} {
      allow read: if isMaster() || isPlatformSales() || isOrgMember(resource.data.organizationId);
      allow write: if isMaster() || isOrgMember(resource.data.organizationId);
      allow create: if isMaster() || isOrgMember(request.resource.data.organizationId);
    }

    match /refrigerantTransactions/{logId} {
      allow read: if isMaster() || isPlatformSales() || isOrgMember(resource.data.organizationId);
      allow write: if isMaster() || isOrgMember(resource.data.organizationId);
      allow create: if isMaster() || isOrgMember(request.resource.data.organizationId);
    }

    match /incidentReports/{reportId} {
      allow read: if isMaster() || isPlatformSales() || isOrgMember(resource.data.organizationId);
      allow write: if isMaster() || isOrgMember(resource.data.organizationId);
      allow create: if isMaster() || isOrgMember(request.resource.data.organizationId);
    }

    match /messages/{messageId} {
      allow read: if isMaster() || isPlatformSales() || isOrgMember(resource.data.organizationId) || isCustomerOwner(resource.data);
      allow write: if isMaster() || isOrgMember(resource.data.organizationId) || isCustomerOwner(resource.data);
      allow create: if true; 
    }

    match /notifications/{notificationId} {
      allow read: if isMaster() || isPlatformSales() || isOrgMember(resource.data.organizationId) || isCustomerOwner(resource.data);
      allow write: if isMaster() || isUser(resource.data.userId) || isCustomerOwner(resource.data);
      allow create: if isSignedIn();
    }

    match /mail/{mailId} {
      allow create: if true;
      allow read: if isMaster() || isPlatformSales() || isOrgMember(resource.data.organizationId);
    }

    match /mail_queue/{queueId} {
      allow create: if true;
      allow read: if isMaster() || isPlatformSales() || isOrgMember(resource.data.organizationId);
    }

    match /pricebook_items/{itemId} {
      allow read: if true; // Allow public read for pricebook items
      allow write: if isMaster() || (isOrgMember(resource.data.organizationId) && isOrgAdmin());
    }
    
    match /business_documents/{docId} {
      allow read: if isMaster() || isPlatformSales() || isOrgMember(resource.data.organizationId) || isCustomerOwner(resource.data);
      allow write: if isMaster() || isOrgMember(resource.data.organizationId);
      allow create: if isMaster() || isOrgMember(request.resource.data.organizationId);
    }
    
    match /documents/{docId} {
      allow get: if true;
      allow list: if isMaster() || isPlatformSales() || isOrgMember(resource.data.organizationId) || isCustomerOwner(resource.data);
      allow write: if isMaster() || isOrgMember(resource.data.organizationId) || isCustomerOwner(resource.data) || (isSignedIn() && request.resource.data.status == 'Signed');
      allow create: if isMaster() || isOrgMember(request.resource.data.organizationId) || isCustomer();
    }

    match /reviews/{reviewId} {
      allow read: if true; 
      allow write: if isMaster() || isOrgMember(resource.data.organizationId);
      allow create: if true; 
    }
    
    match /applicants/{appId} {
       allow read: if isMaster() || isPlatformSales() || (resource != null && isFranchiseAdmin(resource.data.get('franchiseId', null))) || isOrgMember(resource.data.organizationId);
       allow write: if isMaster() || (resource != null && isFranchiseAdmin(resource.data.get('franchiseId', null))) || isOrgMember(resource.data.organizationId);
       allow create: if true; 
    }
    
    match /inspectionTemplates/{templateId} {
      allow read: if isMaster() || isPlatformSales() || isOrgMember(resource.data.organizationId);
      allow write: if isMaster() || isOrgMember(resource.data.organizationId);
      allow create: if isMaster() || isOrgMember(request.resource.data.organizationId);
    }
    
    match /platformSettings/{settingId} {
       allow read: if true;
       allow write: if isMaster();
    }
    
    match /settings/{settingId} {
       allow read: if true;
       allow write: if isMaster();
    }

    match /promoCodes/{codeId} {
       allow read: if true;
       allow write: if isMaster();
    }

    match /public/{docId} {
      allow read: if true;
    }

    match /aiUsage/{docId} {
      // Platform Sales or Master Admin can read/list all usage
      allow read, list: if isMaster() || isPlatformSales();
      // Organizations can read their own usage document
      allow read: if isOrgMember(docId);
      // Only cloud functions can create/write to this, so no write permissions are granted to clients
      allow write: if false; 
    }

    match /aiActivityLogs/{logId} {
      allow read: if isMaster() || isPlatformSales() || isOrgMember(resource.data.organizationId);
      // Audit logs are immutable from the client-side. They are ONLY written securely by the aiAgentCloud Function.
      allow write: if false; 
    }

    match /marketingCampaigns/{campaignId} {
      allow read: if isMaster() || isPlatformSales() || (isOrgMember(resource.data.organizationId) && isOrgAdmin());
      allow write: if isMaster() || isPlatformSales() || (isOrgMember(resource.data.organizationId) && isOrgAdmin());
      allow create: if isMaster() || isPlatformSales() || (isOrgMember(request.resource.data.organizationId) && isOrgAdmin());
    }

    match /storageUsage/{docId} {
      // Platform Sales/Admins can read all metrics
      allow list: if isMaster() || isPlatformSales();
      // Users can securely read/update their own tenant's metric logs during active file uploads
      allow read, write: if isMaster() || isPlatformSales() || isOrgMember(docId);
    }

    match /rfp_notices/{noticeId} {
      allow read: if isMaster() || isPlatformSales() || (resource != null && (resource.data.visibility == 'Public' || isOrgMember(resource.data.organizationId)));
      allow write: if isMaster() || isPlatformSales() || isOrgMember(resource.data.organizationId);
      allow create: if isMaster() || isPlatformSales() || isOrgMember(request.resource.data.organizationId);

      match /submissions/{submissionId} {
        allow read: if isMaster() || isPlatformSales() || isOrgMember(get(/databases/$(database)/documents/rfp_notices/$(noticeId)).data.organizationId) || isOrgMember(resource.data.organizationId);
        allow write: if isMaster() || isPlatformSales() || isOrgMember(request.resource.data.organizationId);
        allow create: if isMaster() || isPlatformSales() || isOrgMember(request.resource.data.organizationId);
      }
    }

    match /bids/{bidId} {
      allow read: if isMaster() || isPlatformSales() || isOrgMember(resource.data.organizationId);
      allow write: if isMaster() || isPlatformSales() || isOrgMember(resource.data.organizationId);
      allow create: if isMaster() || isPlatformSales() || isOrgMember(request.resource.data.organizationId);
    }

    match /platformSettings/{settingId} {
      allow read: if true;
      allow write: if isMaster() || isPlatformSales();
    }

    match /masterData/{document=**} {
      allow read, write: if isMaster();
    }

    // Platform Campaign Studio: mailing lists (master admin + platform sales)
    match /platform_mailing_lists/{listId} {
      allow read, write: if isMaster() || isPlatformSales();
    }

    // Platform Campaign Studio: saved email templates (master admin + platform sales)
    match /platform_campaign_templates/{templateId} {
      allow read, write: if isMaster() || isPlatformSales();
    }
  }
}
