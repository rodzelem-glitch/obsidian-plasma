	<string>We need Bluetooth access to connect to mobile receipt printers and other field devices.</string>
	<key>NSBluetoothPeripheralUsageDescription</key>
	<string>We need Bluetooth access to discover and connect to external hardware like receipt printers.</string>
	<key>CFBundleURLTypes</key>
	<array>
		<dict>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>com.googleusercontent.apps.655867451194-gk7g5mg1rt145jgpov7utcv9jcqbmn1v</string>
			</array>
		</dict>
	</array>
