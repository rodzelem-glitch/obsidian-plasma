rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    // Helper: checks if user is authenticated
    function isSignedIn() {
      return request.auth != null;
    }

    // Helper: checks if user has an organizationId in their token
    function getOrgId() {
      return request.auth.token.organizationId;
    }

    // Default: allow users to read/write their own organization's files
    match /{allPaths=**} {
      allow read, write: if isSignedIn();
    }

    // Specific path for Bids
    match /bids/{orgId}/{bidId}/{fileName} {
      allow read, write: if isSignedIn() && (orgId == getOrgId() || request.auth.token.role == 'master_admin');
    }

    // AI Chat images
    match /ai_chats/{orgId}/{jobId}/{fileName} {
      allow read, write: if isSignedIn() && (orgId == getOrgId() || request.auth.token.role == 'master_admin');
    }
  }
}
